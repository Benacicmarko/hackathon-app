# Default: SQLite file at prisma/dev.db (no Docker). Override with PostgreSQL if you prefer.
# DATABASE_URL="file:./prisma/dev.db"
# DATABASE_URL="postgresql://carpool:carpool_local@localhost:5432/carpool?schema=public"

# Google Maps (Geocoding + Routes). Leave empty for local dev — API uses deterministic mock coordinates and legs.
GOOGLE_MAPS_API_KEY=

# Firebase Admin — same project as iOS (GoogleService-Info.plist PROJECT_ID). Omit in development to auto-disable token verification.
# FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccountKey.json

# Force Firebase on in development: DISABLE_AUTH=false
# Force auth off in production (not recommended): DISABLE_AUTH=true

PORT=3000
HOST=0.0.0.0
